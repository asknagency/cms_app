  "themes": [
    {
      "id": "theme-f334cb7d-72d4-45ea-adc4-6c9e4f83edc8",
      "name": "classic",
      "fontUrl": "",
      "styleMap": {
        "--theme-primary": "#14b8a6",
        "--theme-surface": "#ffffff",
        "--theme-font": "Inter, sans-serif"
      },
      "files": [
        {
          "name": "index.html",
          "path": "themes/classic/index.html",
          "content": "<!DOCTYPE html>\n<html lang=\"en\" class=\"light\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \n  <title>{{page.title}} | {{site.name}}</title>\n  <meta name=\"description\" content=\"{{page.description}}\">\n  <meta property=\"og:title\" content=\"{{page.title}}\">\n  <meta property=\"og:description\" content=\"{{page.description}}\">\n  <meta property=\"og:type\" content=\"website\">\n  \n  {{{head_inject}}}\n  {{{cms_data}}}\n</head>\n<body class=\"bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col\">\n\n  <header class=\"bg-white border-b border-gray-200 sticky top-0 z-50\">\n    <div class=\"max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center\">\n      <a href=\"/\" class=\"text-xl font-bold text-[var(--primary, #14b8a6)]\">{{site.name}}</a>\n      <nav class=\"text-sm font-medium text-gray-500\">\n        <a href=\"/\" class=\"hover:text-gray-900 transition-colors\">Home</a>\n      </nav>\n    </div>\n  </header>\n\n  <main class=\"flex-1 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full\">\n    <div class=\"mb-8\">\n      <h1 class=\"text-3xl font-bold tracking-tight\">Latest Updates</h1>\n      <p class=\"text-gray-500 mt-2\">{{site.description}}</p>\n    </div>\n\n    <div id=\"post-grid\" class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n      </div>\n  </main>\n\n  <footer class=\"bg-white border-t border-gray-200 mt-auto\">\n    <div class=\"max-w-5xl mx-auto px-4 py-6 text-center text-sm text-gray-500\">\n      &copy; <script>document.write(new Date().getFullYear())</script> {{site.name}}. All rights reserved.\n    </div>\n  </footer>\n\n  <script>\n    document.addEventListener('DOMContentLoaded', () => {\n      const grid = document.getElementById('post-grid');\n      const data = window._CMS_DATA;\n\n      if (!data || !data.posts || data.posts.length === 0) {\n        grid.innerHTML = '<p class=\"text-gray-500 col-span-full py-10 text-center\">No posts published yet.</p>';\n        return;\n      }\n\n      // Sort posts by date (newest first)\n      const sortedPosts = data.posts.sort((a, b) => new Date(b.date) - new Date(a.date));\n\n      grid.innerHTML = sortedPosts.map(post => `\n        <a href=\"layout.html?p=${post.slug || post.id}\" class=\"group flex flex-col bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-all hover:border-[var(--primary, #14b8a6)]\">\n          ${post.featuredImage \n            ? `<img src=\"${post.featuredImage}\" alt=\"${post.title}\" class=\"w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500\">`\n            : `<div class=\"w-full h-48 bg-gray-100 flex items-center justify-center text-gray-400\"><svg class=\"w-10 h-10\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z\"></path></svg></div>`\n          }\n          <div class=\"p-5 flex flex-col flex-1\">\n            <h2 class=\"text-lg font-bold mb-2 group-hover:text-[var(--primary, #14b8a6)] transition-colors line-clamp-2\">${post.title}</h2>\n            <p class=\"text-sm text-gray-500 mb-4 line-clamp-3 flex-1\">${post.seoDescription || 'Read more about this topic...'}</p>\n            <div class=\"flex items-center text-xs text-gray-400 font-medium mt-auto pt-4 border-t border-gray-100\">\n              <span>${post.date ? new Date(post.date).toLocaleDateString() : 'Recent'}</span>\n            </div>\n          </div>\n        </a>\n      `).join('');\n    });\n  </script>\n</body>\n</html>"
        },
        {
          "name": "layout.html",
          "path": "themes/classic/layout.html",
          "content": "<!DOCTYPE html>\n<html lang=\"en\" class=\"light\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \n  <title>{{page.title}} | {{site.name}}</title>\n  <meta name=\"description\" content=\"{{page.description}}\">\n  \n  <script src=\"https://cdn.jsdelivr.net/npm/marked/marked.min.js\"></script>\n\n  {{{head_inject}}}\n  {{{cms_data}}}\n</head>\n<body class=\"bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col\">\n\n  <header class=\"bg-white border-b border-gray-200 sticky top-0 z-50\">\n    <div class=\"max-w-3xl mx-auto px-4 py-4 flex justify-between items-center\">\n      <a href=\"/\" class=\"text-xl font-bold text-[var(--primary, #14b8a6)]\">{{site.name}}</a>\n      <a href=\"/\" class=\"text-sm font-medium text-gray-500 hover:text-gray-900\">&larr; Back to Feed</a>\n    </div>\n  </header>\n\n  <main class=\"flex-1 max-w-3xl mx-auto px-4 py-10 w-full bg-white shadow-sm sm:my-8 sm:rounded-2xl sm:border border-gray-100\">\n    <article id=\"post-container\" class=\"prose prose-lg max-w-none prose-a:text-[var(--primary,#14b8a6)]\">\n      <div class=\"animate-pulse flex flex-col space-y-4\">\n        <div class=\"h-8 bg-gray-200 rounded w-3/4\"></div>\n        <div class=\"h-4 bg-gray-200 rounded w-1/4 mb-8\"></div>\n        <div class=\"h-64 bg-gray-200 rounded w-full\"></div>\n        <div class=\"h-4 bg-gray-200 rounded w-full\"></div>\n        <div class=\"h-4 bg-gray-200 rounded w-5/6\"></div>\n      </div>\n    </article>\n  </main>\n\n  <footer class=\"bg-white border-t border-gray-200 mt-auto\">\n    <div class=\"max-w-3xl mx-auto px-4 py-6 text-center text-sm text-gray-500\">\n      &copy; <script>document.write(new Date().getFullYear())</script> {{site.name}}.\n    </div>\n  </footer>\n\n  <script>\n    document.addEventListener('DOMContentLoaded', () => {\n      const container = document.getElementById('post-container');\n      const data = window._CMS_DATA;\n      \n      // Get post slug from URL\n      const urlParams = new URLSearchParams(window.location.search);\n      const postSlug = urlParams.get('p');\n\n      if (!data || !data.posts) return (container.innerHTML = '<h1>Database Error</h1>');\n      \n      const post = data.posts.find(p => p.slug === postSlug || p.id === postSlug);\n      \n      if (!post) {\n        window.location.href = '404.html';\n        return;\n      }\n\n      // Update document title dynamically based on the specific post\n      document.title = `${post.title} | ${data.settings.siteName}`;\n\n      // Render Blocks\n      let htmlContent = '';\n      \n      // Render Header\n      if (post.featuredImage) {\n        htmlContent += `<img src=\"${post.featuredImage}\" alt=\"${post.title}\" class=\"w-full h-[400px] object-cover rounded-xl mb-8\">`;\n      }\n      htmlContent += `<h1 class=\"text-4xl font-extrabold tracking-tight mb-2\">${post.title}</h1>`;\n      if (post.date) {\n        htmlContent += `<p class=\"text-gray-500 text-sm mb-8 font-medium\">Published on ${new Date(post.date).toLocaleDateString()}</p>`;\n      }\n\n      // Process CMS JSON Blocks\n      if (post.blocks && Array.isArray(post.blocks)) {\n        post.blocks.forEach(block => {\n          if (block.type === 'text') {\n            htmlContent += marked.parse(block.content || '');\n          } else if (block.type === 'image' && block.src) {\n            htmlContent += `<figure class=\"my-8\"><img src=\"${block.src}\" alt=\"${block.alt || ''}\" class=\"rounded-lg w-full h-auto\" loading=\"lazy\"><figcaption class=\"text-center text-sm text-gray-500 mt-2\">${block.caption || ''}</figcaption></figure>`;\n          } else if (block.type === 'video' && block.url) {\n            let embedUrl = block.url;\n            if (embedUrl.includes('youtube.com/watch?v=')) embedUrl = embedUrl.replace('watch?v=', 'embed/');\n            else if (embedUrl.includes('youtu.be/')) embedUrl = embedUrl.replace('youtu.be/', 'youtube.com/embed/');\n            htmlContent += `<div class=\"aspect-video w-full my-8\"><iframe src=\"${embedUrl}\" class=\"w-full h-full rounded-lg\" frameborder=\"0\" allowfullscreen></iframe></div>`;\n          }\n        });\n      }\n\n      container.innerHTML = htmlContent;\n    });\n  </script>\n</body>\n</html>"
        },
        {
          "name": "404.html",
          "path": "themes/classic/404.html",
          "content": "<!DOCTYPE html>\n<html lang=\"en\" class=\"light\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Page Not Found | {{site.name}}</title>\n  \n  {{{head_inject}}}\n</head>\n<body class=\"bg-gray-50 text-gray-900 font-sans antialiased h-screen flex flex-col items-center justify-center\">\n\n  <div class=\"max-w-md w-full px-6 text-center\">\n    <div class=\"text-[var(--primary, #14b8a6)] mb-6\">\n      <svg class=\"w-24 h-24 mx-auto\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"></path>\n      </svg>\n    </div>\n    \n    <h1 class=\"text-4xl font-extrabold tracking-tight mb-2\">404</h1>\n    <h2 class=\"text-xl font-bold text-gray-700 mb-4\">Page not found</h2>\n    <p class=\"text-gray-500 mb-8\">Sorry, we couldn't find the page you're looking for. It might have been moved or deleted.</p>\n    \n    <a href=\"/\" class=\"inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-[var(--primary,#14b8a6)] hover:opacity-90 shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[var(--primary,#14b8a6)]\">\n      Return to Homepage\n    </a>\n  </div>\n\n</body>\n</html>"
        }
      ],
